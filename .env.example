# Docker socket used by DockerOperator
DOCKER_HOST=unix://var/run/docker.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_GID=101

# DAG variables
# IMPORTANT: Set to an absolute host path the Docker daemon can access.
CITYJSON_WORK_DIR=/absolute/path/to/Regensburg_DigitalerEnergieZwilling_AirflowDAGs/data
# CITYJSON_SRC_SRS=
# CITYJSON_APPEARANCE=rgbTexture
CITYJSON_THREAD_COUNT=4
# CITYJSON_HAS_ALPHA_ENABLED=true
CITYJSON_SIMPLIFY_ADDRESSES=false
CITYJSON_SHOW_STACK_TRACE=false

# LocalStack S3 simulation
# Use this endpoint inside Docker containers (Airflow, scheduler, tasks).
AWS_ENDPOINT_URL_S3=http://localstack:4566
AWS_DEFAULT_REGION=eu-central-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_BUCKET=external-downloads
LOCALSTACK_DEBUG=0
S3_GUI_PORT=3000
