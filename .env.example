CITYJSON_WORK_DIR=/path/to/project/workdir

AIRFLOW__CORE__LOAD_EXAMPLES=False

DOCKER_HOST=unix:///var/run/docker.sock

CITYJSON_THREAD_COUNT=4
CITYJSON_SIMPLIFY_ADDRESSES=false
CITYJSON_SHOW_STACK_TRACE=false

# S3 credentials — used by Airflow/DAGs (host process)
AWS_ENDPOINT_URL_S3=https://your-s3-host
AWS_DEFAULT_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key

# S3 GUI — endpoint must be reachable from inside Docker
# For external server: same as AWS_ENDPOINT_URL_S3
# For localstack: http://localstack:4566
S3_GUI_ENDPOINT=https://your-s3-host
S3_BUCKET_NAMES=det-rg-upload,det-rg-gml,det-rg-json,det-rg-main
S3_GUI_PORT=3000

# Only needed when running with --profile local
LOCALSTACK_DEBUG=0