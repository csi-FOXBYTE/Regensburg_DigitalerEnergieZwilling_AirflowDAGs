AIRFLOW_UID=50000
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# Docker socket used by DockerOperator
DOCKER_HOST=unix://var/run/docker.sock
DOCKER_SOCKET_PATH=/var/run/docker.sock
DOCKER_GID=101

# DAG variables
# IMPORTANT: Set to an absolute host path the Docker daemon can access.
CITYJSON_WORK_DIR=/absolute/path/to/Regensburg_DigitalerEnergieZwilling_AirflowDAGs/data/cityjson-to-3d-tiles
CITYGML_UPLOAD_DIR=/absolute/path/to/Regensburg_DigitalerEnergieZwilling_AirflowDAGs/data/uploads
CITYJSON_STORAGE_DIR=/absolute/path/to/Regensburg_DigitalerEnergieZwilling_AirflowDAGs/data/storage
CITYJSON_SRC_SRS=
CITYJSON_DEST_SRS=
CITYJSON_APPEARANCE=rgbTexture
CITYJSON_THREAD_COUNT=4
CITYJSON_HAS_ALPHA_ENABLED=true
CITYJSON_SIMPLIFY_ADDRESSES=false
CITYJSON_SHOW_STACK_TRACE=false
